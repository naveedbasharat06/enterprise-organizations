# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use default SQLite (backend/db.sqlite3)
# For Docker it is set automatically in docker-compose.yml
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost/rolebase
DATABASE_URL=

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── Groq API (free Whisper transcription) ─────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# ── Celery / Redis ────────────────────────────────────────────────────────────
# For local dev (without Docker): redis://localhost:6379/0
# For Docker: set automatically in docker-compose.yml
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Stripe (test mode) ────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
# Get this from https://dashboard.stripe.com/test/webhooks after creating a webhook
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Run: docker compose exec backend python manage.py setup_stripe
# Then paste the printed Price IDs below:
STRIPE_BASIC_MONTHLY_PRICE_ID=price_
STRIPE_BASIC_ANNUAL_PRICE_ID=price_
STRIPE_PRO_MONTHLY_PRICE_ID=price_
STRIPE_PRO_ANNUAL_PRICE_ID=price_
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_
STRIPE_BASIC_METERED_PRICE_ID=price_
STRIPE_PRO_METERED_PRICE_ID=price_
STRIPE_PREMIUM_METERED_PRICE_ID=price_
