# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use default SQLite (backend/db.sqlite3)
# For Docker it is set automatically in docker-compose.yml
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost/rolebase
DATABASE_URL=

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── Groq API (free Whisper transcription) ─────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# ── Celery / Redis ────────────────────────────────────────────────────────────
# For local dev (without Docker): redis://localhost:6379/0
# For Docker: set automatically in docker-compose.yml
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
